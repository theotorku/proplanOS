# ============================================================
# ProPlan Agent OS — Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values

# Anthropic Claude (optional — falls back to mock LLMs if not set)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Supabase (optional — falls back to in-memory database if not set)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-key-here

# API Authentication (optional — skipped if not set)
API_SECRET_KEY=your-api-secret-key

# CORS Origins (comma-separated, defaults to http://localhost:5173)
ALLOWED_ORIGINS=http://localhost:5173

# Redis / Celery (optional — async endpoint disabled if not set)
REDIS_URL=redis://localhost:6379/0

# Google Places API (optional — onboarding URL-scan falls back to site title only if missing)
# Used by POST /onboard/scan to enrich a business URL with location, vertical,
# and one recent customer review (the onboarding proof moment).
GOOGLE_PLACES_API_KEY=

# ============================================================
# Embeddable chat agent
# ============================================================
# Model used for the /agent/chat/message stream. Defaults to the same Sonnet
# model the orchestrator uses, so a missing var still gets you a working chat.
CHAT_MODEL=claude-sonnet-4-6

# Calendly (or any scheduling) URL returned by /agent/chat/book_call.
CALENDLY_URL=https://calendly.com/proplan/intro

# Slack incoming-webhook URL used by /agent/chat/escalate and the
# capture_lead / book_call notifications. Separate from the per-user
# webhook on business_profiles so the chat agent routes to a shared
# team channel regardless of which visitor is talking.
CHAT_SLACK_WEBHOOK_URL=

# Abuse controls for the public chat endpoints.
CHAT_RATE_LIMIT_PER_CONVO=30
CHAT_IP_CONVOS_PER_HOUR=100
CHAT_COST_CAP_USD=0.30
